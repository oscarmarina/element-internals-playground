{
  "name": "element-internals-playground",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm package-lock.json && lerna clean",
    "clean:packages": "lerna exec -- rm -rf ./node_modules && npm run clean:packages:dev && npm run clean:packages:coverage",
    "clean:packages:coverage": "lerna exec -- rm -rf ./test/coverage",
    "clean:packages:dev": "lerna exec -- rm -rf ./dev && lerna exec -- rm -rf ./package-lock.json",
    "eslint": "eslint --fix 'packages/**/*.*'",
    "format": "lerna run format --stream --concurrency 1",
    "test": "lerna run test --stream --concurrency 1 -- --run",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{js,ts,html}": [
      "npm run lint"
    ],
    "**/*.json": [
      "npm run prettier"
    ],
    "**/*.{scss,css}": [
      "npm run prettier",
      "npm run stylelint"
    ]
  },
  "prettier": {
    "bracketSpacing": false,
    "bracketSameLine": true,
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "es5",
    "overrides": [
      {
        "files": "*.{scss,css}",
        "options": {
          "singleQuote": false
        }
      },
      {
        "files": "*.json",
        "options": {
          "parser": "json-stringify"
        }
      }
    ]
  },
  "stylelint": {
    "extends": "stylelint-config-standard-scss",
    "allowEmptyInput": true,
    "rules": {
      "custom-property-pattern": null,
      "no-duplicate-selectors": null,
      "color-function-notation": null,
      "alpha-value-notation": null,
      "media-feature-name-no-unknown": null,
      "comment-empty-line-before": null,
      "declaration-empty-line-before": null,
      "property-no-vendor-prefix": null,
      "selector-attribute-quotes": null,
      "value-no-vendor-prefix": null
    },
    "overrides": [
      {
        "files": [
          "**/*.html"
        ],
        "customSyntax": "postcss-html"
      },
      {
        "files": [
          "**/*.{ts,js}"
        ],
        "customSyntax": "postcss-lit"
      }
    ]
  },
  "overrides": {
    "axios": "^1.16.1",
    "nx": {
      "brace-expansion": "^5.0.6"
    },
    "follow-redirects": "^1.16.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "commit-and-tag-version": "^12.7.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.3.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.4",
    "@html-eslint/eslint-plugin": "^0.60.0",
    "@html-eslint/parser": "^0.60.0",
    "prettier": "^3.8.3",
    "@typescript-eslint/parser": "^8.59.3",
    "typescript-eslint": "^8.59.3",
    "stylelint": "^17.11.1"
  },
  "stackblitz": {
    "startCommand": "npm --prefix packages/blk-input start"
  }
}
